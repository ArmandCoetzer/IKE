SA_PASSWORD=YourStrong!Passw0rd123
APP_DB_USER=ike_app
APP_DB_PASSWORD=YourAppDbStrong!Passw0rd123
SQL_VOLUME_NAME=ike_sql_data_prod
UPLOADS_VOLUME_NAME=ike_uploads_prod
# Required only when using docker-compose.cloudflare.yml.
# Create a Cloudflare Tunnel and paste its token here.
CLOUDFLARE_TUNNEL_TOKEN=
# Generate once and keep secret (base64, decodes to >= 32 bytes).
JWT_KEY_BASE64=REPLACE_WITH_BASE64_KEY
# Email provider: Smtp or MicrosoftGraph. For Microsoft 365 Security Defaults, use MicrosoftGraph.
EMAIL_PROVIDER=Smtp
# Optional but recommended when EMAIL_PROVIDER=Smtp.
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
# Required only when EMAIL_PROVIDER=MicrosoftGraph.
MICROSOFT_GRAPH_TENANT_ID=
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
MICROSOFT_GRAPH_FROM_EMAIL=admin@ikegroup.co.za
MICROSOFT_GRAPH_FROM_NAME=IKE
# Required for first production bootstrap. Change immediately after first login.
DEFAULT_ADMIN_EMAIL=admin@ikegroup.co.za
DEFAULT_ADMIN_PASSWORD=REPLACE_WITH_STRONG_DEFAULT_ADMIN_PASSWORD
DEFAULT_ADMIN_FULL_NAME=Default Admin
